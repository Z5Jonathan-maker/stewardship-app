# Unite Financial — environment variables
# Copy to .env.local and fill in. .env.local is gitignored.

# Powers the "Ask Unite" assistant (app/api/assistant). Get a key at
# https://console.anthropic.com . If unset, the assistant falls back to a
# local stewardship mock so the app still works in demos.
ANTHROPIC_API_KEY=

# Plaid — powers real bank connections (app/api/plaid/*). Get free Sandbox
# credentials at https://dashboard.plaid.com . If unset, "Connect account"
# falls back to a local mock institution picker so the app still works.
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox (default) | production
PLAID_ENV=sandbox
