# Unite Financial — environment variables
# Copy to .env.local and fill in. .env.local is gitignored.

# Powers the "Ask Unite" assistant (app/api/assistant). Get a key at
# https://console.anthropic.com . If unset, the assistant falls back to a
# local stewardship mock so the app still works in demos.
ANTHROPIC_API_KEY=

# Plaid — powers real bank connections (app/api/plaid/*). Get free Sandbox
# credentials at https://dashboard.plaid.com . If unset, "Connect account"
# falls back to a local mock institution picker so the app still works.
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox (default) | production
PLAID_ENV=sandbox

# Database — Postgres (Neon recommended). When unset, the app reads the in-repo
# mock household and builds/runs normally (see ARCHITECTURE.md). DATABASE_URL is
# the pooled connection (runtime); DATABASE_URL_UNPOOLED is the direct
# connection used by Drizzle Kit migrations.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Auth — Clerk. When unset, the demo auth flow is used (login/signup drop into
# the app). Required for real per-household accounts.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
